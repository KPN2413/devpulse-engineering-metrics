generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  displayName       String?
  githubId          String    @unique
  githubAccessToken String?
  repositories      Repository[]
  createdAt         DateTime  @default(now())
}

model Organization {
  id            String    @id @default(cuid())
  name          String
  githubId      String    @unique
  repositories  Repository[]
  createdAt     DateTime  @default(now())
}

model Repository {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  orgId         String?
  org           Organization? @relation(fields: [orgId], references: [id])
  name          String
  owner         String
  githubId      String    @unique
  webhookId     String?
  pullRequests  PullRequest[]
  metrics       Metric[]
  createdAt     DateTime  @default(now())
}

model PullRequest {
  id            String    @id @default(cuid())
  githubPrId    String    @unique
  repoId        String
  repository    Repository @relation(fields: [repoId], references: [id])
  title         String
  authorLogin   String
  openedAt      DateTime
  mergedAt      DateTime?
  closedAt      DateTime?
  cycleTimeMs   BigInt?
}

model Commit {
  id            String    @id @default(cuid())
  repoId        String
  sha           String    @unique
  author        String
  message       String?
  committedAt   DateTime
}

model WebhookEvent {
  id            String    @id @default(cuid())
  repoId        String?
  eventType     String
  payload       Json
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
}

model Metric {
  id                String    @id @default(cuid())
  repoId            String
  repository        Repository @relation(fields: [repoId], references: [id])
  date              DateTime  // Day-truncated
  prCount           Int       @default(0)
  commitCount       Int       @default(0)
  avgCycleTimeMs    Float     @default(0)
  avgReviewTimeMs   Float     @default(0)

  @@unique([repoId, date])
}
